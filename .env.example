# Frontend (Nuxt) — copy to apps/web/.env for local dev
NUXT_PUBLIC_API_URL=http://localhost:8000
NUXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55431
NUXT_PUBLIC_SUPABASE_ANON_KEY=

# Backend (FastAPI) — copy to services/api/.env for local dev
# Run: supabase status (from repo root) for local keys
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=
CORS_ORIGINS=http://localhost:3000
